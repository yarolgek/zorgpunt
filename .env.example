# Production site URL (include www). Used for canonical URLs, OG images, sitemap and schema.
NEXT_PUBLIC_SITE_URL=https://www.zorgpuntconnect.nl

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). Enables Consent Mode v2 + GA4/Ads tags.
# Leave empty during development to skip loading Google scripts.
NEXT_PUBLIC_GTM_ID=
